{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { computed, ref } from 'vue';\nimport { required, shouldNotExceedCharLength } from '@/core/util/validation/rules';\nimport { APIService } from '@/core/util/services/api.service';\nimport usePaginate from '@ohrm/core/util/composable/usePaginate';\nimport EmployeeAutocomplete from '@/core/components/inputs/EmployeeAutocomplete';\nimport useEmployeeNameTranslate from '@/core/util/composable/useEmployeeNameTranslate';\nexport default {\n  components: {\n    'employee-autocomplete': EmployeeAutocomplete\n  },\n  setup() {\n    const {\n      $tEmpName\n    } = useEmployeeNameTranslate();\n    const now = new Date();\n    const currentMonth = now.getMonth() + 1;\n    const currentYear = now.getFullYear();\n    const monthOptions = [{\n      id: 1,\n      label: 'January'\n    }, {\n      id: 2,\n      label: 'February'\n    }, {\n      id: 3,\n      label: 'March'\n    }, {\n      id: 4,\n      label: 'April'\n    }, {\n      id: 5,\n      label: 'May'\n    }, {\n      id: 6,\n      label: 'June'\n    }, {\n      id: 7,\n      label: 'July'\n    }, {\n      id: 8,\n      label: 'August'\n    }, {\n      id: 9,\n      label: 'September'\n    }, {\n      id: 10,\n      label: 'October'\n    }, {\n      id: 11,\n      label: 'November'\n    }, {\n      id: 12,\n      label: 'December'\n    }];\n    const yearOptions = [];\n    for (let y = currentYear; y >= currentYear - 5; y--) {\n      yearOptions.push({\n        id: y,\n        label: String(y)\n      });\n    }\n    const filters = ref({\n      employee: null,\n      month: monthOptions.find(m => m.id === currentMonth),\n      year: yearOptions.find(y => y.id === currentYear)\n    });\n    const rules = {\n      employee: [shouldNotExceedCharLength(100)],\n      month: [required],\n      year: [required]\n    };\n    const serializedFilters = computed(() => {\n      const month = filters.value.month?.id;\n      const year = filters.value.year?.id;\n      if (!month || !year) return {};\n      const mm = String(month).padStart(2, '0');\n      const lastDay = new Date(year, month, 0).getDate();\n      return {\n        fromDate: `${year}-${mm}-01`,\n        toDate: `${year}-${mm}-${String(lastDay).padStart(2, '0')}`,\n        empNumber: filters.value.employee?.id\n      };\n    });\n    const normalizer = data => {\n      return data.map(item => {\n        const status = item.completed9Hours;\n        return {\n          empNumber: item.empNumber,\n          employeeId: item.employeeId,\n          empName: $tEmpName(item, {\n            includeMiddle: false,\n            excludePastEmpTag: false\n          }),\n          date: item.workDate,\n          duration: item.duration?.label ?? '0:00',\n          status: status ? 'Present' : 'Absent',\n          _cellClasses: {\n            status: status ? 'compliance-status--present' : 'compliance-status--absent'\n          }\n        };\n      });\n    };\n    const http = new APIService(window.appGlobal.baseUrl, '/api/v2/attendance/employees/daily-hours-compliance');\n    const {\n      total,\n      pages,\n      response,\n      isLoading,\n      execQuery,\n      currentPage,\n      showPaginator\n    } = usePaginate(http, {\n      query: serializedFilters,\n      normalizer\n    });\n    return {\n      http,\n      rules,\n      total,\n      pages,\n      filters,\n      isLoading,\n      execQuery,\n      currentPage,\n      showPaginator,\n      items: response,\n      monthOptions,\n      yearOptions\n    };\n  },\n  data() {\n    return {\n      headers: [{\n        name: 'employeeId',\n        title: 'Employee ID',\n        style: {\n          flex: '10%'\n        }\n      }, {\n        name: 'empName',\n        slot: 'title',\n        title: 'Employee Name',\n        style: {\n          flex: '25%'\n        }\n      }, {\n        name: 'date',\n        title: 'Date',\n        style: {\n          flex: '15%'\n        }\n      }, {\n        name: 'duration',\n        title: 'Total Hours',\n        style: {\n          flex: '20%'\n        }\n      }, {\n        name: 'status',\n        title: 'Status (9 Hrs)',\n        style: {\n          flex: '15%'\n        }\n      }]\n    };\n  },\n  methods: {\n    async filterItems() {\n      await this.execQuery();\n    }\n  }\n};","map":{"version":3,"mappings":";AA6FA,SAAQA,QAAQ,EAAEC,GAAG,QAAO,KAAK;AACjC,SACEC,QAAQ,EACRC,yBAAyB,QACpB,8BAA8B;AACrC,SAAQC,UAAU,QAAO,kCAAkC;AAC3D,OAAOC,WAAU,MAAO,wCAAwC;AAChE,OAAOC,oBAAmB,MAAO,+CAA+C;AAChF,OAAOC,wBAAuB,MAAO,iDAAiD;AAEtF,eAAe;EACbC,UAAU,EAAE;IACV,uBAAuB,EAAEF;EAC3B,CAAC;EAEDG,KAAK,GAAG;IACN,MAAM;MAACC;IAAS,IAAIH,wBAAwB,EAAE;IAE9C,MAAMI,GAAE,GAAI,IAAIC,IAAI,EAAE;IACtB,MAAMC,YAAW,GAAIF,GAAG,CAACG,QAAQ,EAAC,GAAI,CAAC;IACvC,MAAMC,WAAU,GAAIJ,GAAG,CAACK,WAAW,EAAE;IAErC,MAAMC,YAAW,GAAI,CACnB;MAACC,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAS,CAAC,EACzB;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAU,CAAC,EAC1B;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAO,CAAC,EACvB;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAO,CAAC,EACvB;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAK,CAAC,EACrB;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAM,CAAC,EACtB;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAM,CAAC,EACtB;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAQ,CAAC,EACxB;MAACD,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE;IAAW,CAAC,EAC3B;MAACD,EAAE,EAAE,EAAE;MAAEC,KAAK,EAAE;IAAS,CAAC,EAC1B;MAACD,EAAE,EAAE,EAAE;MAAEC,KAAK,EAAE;IAAU,CAAC,EAC3B;MAACD,EAAE,EAAE,EAAE;MAAEC,KAAK,EAAE;IAAU,CAAC,CAC5B;IAED,MAAMC,WAAU,GAAI,EAAE;IACtB,KAAK,IAAIC,IAAIN,WAAW,EAAEM,KAAKN,WAAU,GAAI,CAAC,EAAEM,CAAC,EAAE,EAAE;MACnDD,WAAW,CAACE,IAAI,CAAC;QAACJ,EAAE,EAAEG,CAAC;QAAEF,KAAK,EAAEI,MAAM,CAACF,CAAC;MAAC,CAAC,CAAC;IAC7C;IAEA,MAAMG,OAAM,GAAIvB,GAAG,CAAC;MAClBwB,QAAQ,EAAE,IAAI;MACdC,KAAK,EAAET,YAAY,CAACU,IAAI,CAAEC,CAAC,IAAKA,CAAC,CAACV,EAAC,KAAML,YAAY,CAAC;MACtDgB,IAAI,EAAET,WAAW,CAACO,IAAI,CAAEN,CAAC,IAAKA,CAAC,CAACH,EAAC,KAAMH,WAAW;IACpD,CAAC,CAAC;IAEF,MAAMe,KAAI,GAAI;MACZL,QAAQ,EAAE,CAACtB,yBAAyB,CAAC,GAAG,CAAC,CAAC;MAC1CuB,KAAK,EAAE,CAACxB,