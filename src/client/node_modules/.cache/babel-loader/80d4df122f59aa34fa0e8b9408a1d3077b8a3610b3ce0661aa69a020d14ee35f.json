AAU;QAChBC,KAAK,EAAE,aAAa;QACpBC,KAAK,EAAE;UAACC,IAAI,EAAE;QAAK;MACrB,CAAC,EACD;QACEH,IAAI,EAAE,QAAQ;QACdC,KAAK,EAAE,gBAAgB;QACvBC,KAAK,EAAE;UAACC,IAAI,EAAE;QAAK;MACrB,CAAC;IAEL,CAAC;EACH,CAAC;EAEDE,OAAO,EAAE;IACP,MAAMC,WAAW,GAAG;MAClB,MAAM,IAAI,CAACZ,SAAS,EAAE;IACxB;EACF;AACF,CAAC","names":["computed","ref","required","shouldNotExceedCharLength","APIService","usePaginate","EmployeeAutocomplete","useEmployeeNameTranslate","components","setup","$tEmpName","now","Date","currentMonth","getMonth","currentYear","getFullYear","monthOptions","id","label","yearOptions","y","push","String","filters","employee","month","find","m","year","rules","serializedFilters","value","mm","padStart","lastDay","getDate","fromDate","toDate","empNumber","normalizer","data","map","item","status","completed9Hours","employeeId","empName","includeMiddle","excludePastEmpTag","date","workDate","duration","_cellClasses","http","window","appGlobal","baseUrl","total","pages","response","isLoading","execQuery","currentPage","showPaginator","query","items","headers","name","title","style","flex","slot","methods","filterItems"],"sourceRoot":"","sources":["/var/www/html/orangehrm/orangehrm/src/client/src/orangehrmAttendancePlugin/pages/DailyHoursCompliance.vue"],"sourcesContent":["<!--\n/**\n * OrangeHRM is a comprehensive Human Resource Management (HRM) System that captures\n * all the essential functionalities required for any enterprise.\n * Copyright (C) 2006 OrangeHRM Inc., http://www.orangehrm.com\n *\n * OrangeHRM is free software: you can redistribute it and/or modify it under the terms of\n * the GNU General Public License as published by the Free Software Foundation, either\n * version 3 of the License, or (at your option) any later version.\n *\n * OrangeHRM is distributed in the hope that it will be useful, but WITHOUT ANY WARRANTY;\n * without even the implied warranty of MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.\n * See the GNU General Public License for more details.\n *\n * You should have received a copy of the GNU General Public License along with OrangeHRM.\n * If not, see <https://www.gnu.org/licenses/>.\n */\n -->\n\n<template>\n  <oxd-table-filter filter-title=\"Daily 9-Hour Compliance Report\">\n    <oxd-form @submit-valid=\"filterItems\">\n      <oxd-form-row>\n        <oxd-grid :cols=\"4\" class=\"orangehrm-full-width-grid\">\n          <oxd-grid-item>\n            <employee-autocomplete\n              v-model=\"filters.employee\"\n              :rules=\"rules.employee\"\n              :params=\"{\n                includeEmployees: 'currentAndPast',\n              }\"\n            />\n          </oxd-grid-item>\n          <oxd-grid-item>\n            <oxd-input-field\n              v-model=\"filters.month\"\n              type=\"select\"\n              label=\"Month\"\n              :options=\"monthOptions\"\n              :rules=\"rules.month\"\n              required\n            />\n          </oxd-grid-item>\n          <oxd-grid-item>\n            <oxd-input-field\n              v-model=\"filters.year\"\n              type=\"select\"\n              label=\"Year\"\n              :options=\"yearOptions\"\n              :rules=\"rules.year\"\n              required\n            />\n          </oxd-grid-item>\n        </oxd-grid>\n      </oxd-form-row>\n\n      <oxd-divider />\n\n      <oxd-form-actions>\n        <required-text />\n        <oxd-button display-type=\"secondary\" label=\"View\" type=\"submit\" />\n      </oxd-form-actions>\n    </oxd-form>\n  </oxd-table-filter>\n  <br />\n  <div class=\"orangehrm-paper-container\">\n    <table-header\n      :total=\"total\"\n      :selected=\"0\"\n      :loading=\"isLoading\"\n      :show-divider=\"false\"\n    ></table-header>\n    <div class=\"orangehrm-container\">\n      <oxd-card-table\n        :headers=\"headers\"\n        :items=\"items?.data\"\n        :selectable=\"false\"\n        :clickable=\"false\"\n        :loading=\"isLoading\"\n        row-decorator=\"oxd-table-decorator-card\"\n      />\n    </div>\n    <div class=\"orangehrm-bottom-container\">\n      <oxd-pagination\n        v-if=\"showPaginator\"\n        v-model:current=\"currentPage\"\n        :length=\"pages\"\n      />\n    </div>\n  </div>\n</template>\n\n<script>\nimport {computed, ref} from 'vue';\nimport {\n  required,\n  shouldNotExceedCharLength,\n} from '@/core/util/validation/rules';\nimport {APIService} from '@/core/util/services/api.service';\nimport usePaginate from '@ohrm/core/util/composable/usePaginate';\nimport EmployeeAutocomplete from '@/core/components/inputs/EmployeeAutocomplete';\nimport useEmployeeNameTranslate from '@/core/util/composable/useEmployeeNameTranslate';\n\nexport default {\n  components: {\n    'employee-autocomplete': EmployeeAutocomplete,\n  },\n\n  setup() {\n    const {$tEmpName} = useEmployeeNameTranslate();\n\n    const now = new Date();\n    const currentMonth = now.getMonth() + 1;\n    const currentYear = now.getFullYear();\n\n    const monthOptions = [\n      {id: 1, label: 'January'},\n      {id: 2, label: 'February'},\n      {id: 3, label: 'March'},\n      {id: 4, label: 'April'},\n      {id: 5, label: 'May'},\n      {id: 6, label: 'June'},\n      {id: 7, label: 'July'},\n      {id: 8, label: 'August'},\n      {id: 9, label: 'September'},\n      {id: 10, label: 'October'},\n      {id: 11, label: 'November'},\n      {id: 12, label: 'December'},\n    ];\n\n    const yearOptions = [];\n    for (let y = currentYear; y >= currentYear - 5; y--) {\n      yearOptions.push({id: y, label: String(y)});\n    }\n\n    const filters = ref({\n      employee: null,\n      month: monthOptions.find((m) => m.id === currentMonth),\n      year: yearOptions.find((y) => y.id === currentYear),\n    });\n\n    const rules = {\n      employee: [shouldNotExceedCharLength(100)],\n      month: [required],\n      year: [required],\n    };\n\n    const serializedFilters = computed(() => {\n      const month = filters.value.month?.id;\n      const year = filters.value.year?.id;\n      if (!month || !year) return {};\n      const mm = String(month).padStart(2, '0');\n      const lastDay = new Date(year, month, 0).getDate();\n      return {\n        fromDate: `${year}-${mm}-01`,\n        toDate: `${year}-${mm}-${String(lastDay).padStart(2, '0')}`,\n        empNumber: filters.value.employee?.id,\n      };\n    });\n\n    const normalizer = (data) => {\n      return data.map((item) => {\n        const status = item.completed9Hours;\n        return {\n          empNumber: item.empNumber,\n          employeeId: item.employeeId,\n          empName: $tEmpName(item, {\n            includeMiddle: false,\n            excludePastEmpTag: false,\n          }),\n          date: item.workDate,\n          duration: item.duration?.label ?? '0:00',\n          status: status ? 'Present' : 'Absent',\n          _cellClasses: {\n            status: status\n              ? 'compliance-status--present'\n              : 'compliance-status--absent',\n          },\n        };\n      });\n    };\n\n    const http = new APIService(\n      window.appGlobal.baseUrl,\n      '/api/v2/attendance/employees/daily-hours-compliance',\n    );\n\n    const {\n      total,\n      pages,\n      response,\n      isLoading,\n      execQuery,\n      currentPage,\n      showPaginator,\n    } = usePaginate(http, {\n      query: serializedFilters,\n      normalizer,\n    });\n\n    return {\n      http,\n      rules,\n      total,\n      pages,\n      filters,\n      isLoading,\n      execQuery,\n      currentPage,\n      showPaginator,\n      items: response,\n      monthOptions,\n      yearOptions,\n    };\n  },\n\n  data() {\n    return {\n      headers: [\n        {\n          name: 'employeeId',\n          title: 'Employee ID',\n          style: {flex: '10%'},\n        },\n        {\n          name: 'empName',\n          slot: 'title',\n          title: 'Employee Name',\n          style: {flex: '25%'},\n        },\n        {\n          name: 'date',\n          title: 'Date',\n          style: {flex: '15%'},\n        },\n        {\n          name: 'duration',\n          title: 'Total Hours',\n          style: {flex: '20%'},\n        },\n        {\n          name: 'status',\n          title: 'Status (9 Hrs)',\n          style: {flex: '15%'},\n        },\n      ],\n    };\n  },\n\n  methods: {\n    async filterItems() {\n      await this.execQuery();\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n::v-deep(.compliance-status--present) {\n  color: #28a745;\n  font-weight: bold;\n}\n::v-deep(.compliance-status--absent) {\n  color: #dc3545;\n  font-weight: bold;\n}\n</style>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}